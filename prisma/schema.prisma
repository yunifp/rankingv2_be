generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  password  String
  roles     UserRole[]
  
  createdAt DateTime   @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamp(0)
  updatedAt DateTime   @updatedAt @db.DateTime(0)

  @@map("user")
}

model OtpLog {
  id        String   @id @default(uuid())
  email     String
  otp       String
  isUsed    Boolean  @default(false)
  expiresAt DateTime @db.DateTime(0)
  createdAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamp(0)

  @@map("otp_log")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  
  users      UserRole[]
  menuAccess RoleMenuAccess[] 

  @@map("role")
}

// Hanya menyimpan Action: "READ", "CREATE", "UPDATE", "DELETE"
model Permission {
  id         String           @id @default(uuid())
  name       String           @unique
  roleAccess RoleMenuAccess[]

  @@map("permission")
}

model Menu {
  id    String  @id @default(uuid())
  title String
  path  String
  icon  String?
  order Int     @default(0)

  parentId String?
  parent   Menu?   @relation("SubMenus", fields: [parentId], references: [id], onDelete: SetNull)
  children Menu[]  @relation("SubMenus")

  roleAccess RoleMenuAccess[] 

  // KOREKSI DI SINI: Menggunakan Timestamp(0)
  createdAt DateTime @default(dbgenerated("CURRENT_TIMESTAMP")) @db.Timestamp(0)
  updatedAt DateTime @updatedAt @db.DateTime(0)

  @@map("menu")
}

model RoleMenuAccess {
  id           String @id @default(uuid())
  roleId       String
  menuId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu       Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, menuId, permissionId])
  @@map("rolemenuaccess")
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("userrole")
}